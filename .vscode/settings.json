{
  "latex-workshop.latex.recipes": [
    {
      "name": "TinyTeX latexmk",
      "tools": [
        "tinytex-latexmk"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "tinytex-latexmk",
      "command": "bash",
      "args": [
        "-lc",
        "cd \"%DIR%\" && PATH=/home/htang228/bin:/home/htang228/.TinyTeX/bin/x86_64-linux:$PATH latexmk -pdf -interaction=nonstopmode -halt-on-error -synctex=1 \"%DOCFILE%\""
      ]
    }
  ]
}
